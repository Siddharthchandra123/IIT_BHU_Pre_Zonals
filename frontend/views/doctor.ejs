<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Diagnostics | AI Health Assistant</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/i18n.js"></script>
    <style>
        .diagnostics-grid {
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
        }

        @media (max-width: 900px) {
            .diagnostics-grid {
                grid-template-columns: 1fr;
            }
        }

        .symptom-selector {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 25px;
        }

        /* The glass card specifically for AI chat */
        .chat-card {
            display: flex;
            flex-direction: column;
            min-height: 500px;
        }

        /* The Result Box - Chat Bubble Style */
        .result-box {
            background: rgba(15, 23, 42, 0.4);
            border: 1px solid rgba(14, 165, 233, 0.2);
            border-radius: 16px;
            padding: 24px;
            margin-top: 25px;
            flex-grow: 1;
            box-shadow: inset 0 2px 10px rgba(0, 0, 0, 0.2);
            font-size: 1.1rem;
            line-height: 1.8;
            color: #f1f5f9;
            overflow-y: auto;
            position: relative;
        }

        .result-box::before {
            content: attr(data-label);
            position: absolute;
            top: -2px;
            left: 20px;
            background: #0f172a;
            padding: 0 10px;
            font-size: 0.8rem;
            color: var(--primary-glow);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-radius: 4px;
        }

        /* Custom scrollbar for result box */
        .result-box::-webkit-scrollbar {
            width: 6px;
        }

        .result-box::-webkit-scrollbar-track {
            background: transparent;
        }

        .result-box::-webkit-scrollbar-thumb {
            background: rgba(148, 163, 184, 0.2);
            border-radius: 10px;
        }

        .loader {
            display: none;
            width: 30px;
            height: 30px;
            border: 3px solid rgba(14, 165, 233, 0.3);
            border-radius: 50%;
            border-top-color: #0ea5e9;
            animation: spin 1s ease-in-out infinite;
            margin: 20px auto;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Doctors Section */
        .doctors-wrapper {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .doctor-profile {
            display: flex;
            align-items: center;
            gap: 20px;
            padding: 20px;
            background: rgba(30, 41, 59, 0.4);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            transition: var(--transition-smooth);
        }

        .doctor-profile:hover {
            background: rgba(30, 41, 59, 0.6);
            border-color: rgba(139, 92, 246, 0.3);
            transform: translateX(10px);
        }

        .doc-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0ea5e9, #6366f1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            flex-shrink: 0;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
            border: 2px solid rgba(255, 255, 255, 0.1);
        }

        .doc-info h3 {
            font-size: 1.3rem;
            margin-bottom: 5px;
            color: #fff;
        }

        .doc-info p {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 12px;
        }

        .doc-actions {
            display: flex;
            gap: 10px;
        }

        .doc-btn {
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: var(--transition-smooth);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-call {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .btn-call:hover {
            background: rgba(255, 255, 255, 0.15);
        }

        .btn-whatsapp {
            background: rgba(34, 197, 94, 0.15);
            color: #4ade80;
            border: 1px solid rgba(34, 197, 94, 0.3);
        }

        .btn-whatsapp:hover {
            background: rgba(34, 197, 94, 0.25);
            box-shadow: 0 0 15px rgba(34, 197, 94, 0.2);
        }

        /* Section Title override */
        .section-header {
            font-size: 1.8rem;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
    </style>
</head>

<body>

    <header class="navbar scrolled" id="navbar">
        <a href="/" class="brand">
            <span style="filter: drop-shadow(0 0 10px var(--primary-accent));">⚕️</span> <span data-i18n="brand_name">AI Chikitsalya</span>
        </a>
        <nav class="nav-links">
            <a href="/" data-i18n="nav_home">Home</a>
            <a href="/home" data-i18n="nav_assistant">AI Assistant</a>
            <a href="/opd" data-i18n="nav_opd">OPD Booking</a>
            <a href="/ambulance" data-i18n="nav_ambulance">Ambulance</a>
            <a href="/hospitals" data-i18n="nav_hospitals">Find Hospitals</a>
            <a href="/pharmacies" data-i18n="nav_pharmacies">Medical Shops</a>
            <a href="/#emergency" style="color: #fca5a5; font-weight: 700;" data-i18n="nav_emergency">Emergency</a>
            
            <select class="language-selector glass-input" onchange="setLanguage(this.value)" 
                style="margin-left: 15px; padding: 5px 10px; height: auto; width: auto; font-size: 0.9rem; background: rgba(15, 23, 42, 0.8); color: white; border: 1px solid rgba(14, 165, 233, 0.3); border-radius: 8px;">
                <option value="en">🇺🇸 EN</option>
                <option value="hi">🇮🇳 HI</option>
                <option value="bn">🇮🇳 BN</option>
            </select>
        </nav>
    </header>

    <main class="main-wrapper">

        <div class="diagnostics-grid">

            <!-- Left Side: AI Interaction -->
            <div class="glass-panel chat-card animate-fade-up">
                <h2 class="section-header">
                    <span style="font-size: 2rem;">🧠</span> <span data-i18n="symptom_analysis_title">Symptom Analysis</span>
                </h2>
                <p style="color: var(--text-muted); margin-bottom: 20px;" data-i18n="symptom_analysis_desc">
                    Select common symptoms or describe how you feel in detail.
                </p>

                <div class="symptom-selector">
                    <button class="badge-pill" type="button" onclick="addSymptom('fever')">🤒 <span data-i18n="symptom_fever">Fever</span></button>
                    <button class="badge-pill" type="button" onclick="addSymptom('body pain')">💪 <span data-i18n="symptom_body_pain">Body Pain</span></button>
                    <button class="badge-pill" type="button" onclick="addSymptom('vomiting')">🤮 <span data-i18n="symptom_vomiting">Vomiting</span></button>
                    <button class="badge-pill" type="button" onclick="addSymptom('weakness')">😓 <span data-i18n="symptom_weakness">Weakness</span></button>
                    <button class="badge-pill" type="button" onclick="addSymptom('headache')">🤕 <span data-i18n="symptom_headache">Headache</span></button>
                    <button class="badge-pill" type="button" onclick="addSymptom('cough')">😷 <span data-i18n="symptom_cough">Cough</span></button>
                    <button class="badge-pill" type="button" onclick="addSymptom('stomach pain')">🤢 <span data-i18n="symptom_stomach_pain">Stomach ache</span></button>
                </div>

                <div style="position: relative; margin-bottom: 20px;">
                    <textarea id="question" class="glass-input" rows="4" data-i18n="placeholder_symptoms"
                        placeholder="Describe your symptoms thoroughly..."></textarea>

                    <button class="btn-glow" style="width: 100%; margin-top: 15px;" onclick="askAI()">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" style="margin-right: 8px;">
                            <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                        </svg>
                        <span data-i18n="btn_analyze">Analyze Symptoms</span>
                    </button>
                </div>

                <!-- Customized File Upload Input -->
                <div style="margin-bottom: 20px;">
                    <label for="imageUpload"
                        style="display: block; color: var(--text-muted); margin-bottom: 8px;" data-i18n="label_upload">Upload Medical Output
                        (X-Ray, Scan, etc.)</label>
                    <input type="file" id="imageUpload" accept="image/*" class="glass-input"
                        style="width: 100%; padding: 10px; cursor: pointer;" />
                </div>
                <!-- Loader -->
                <div id="loader" class="loader"></div>

                <!-- Results container -->
                <div id="result" class="result-box" data-label-i18n="ai_analysis" data-label="AI Analysis">
                    <div style="text-align: center; color: var(--text-muted); opacity: 0.6; margin-top: 20%;">
                        <div style="font-size: 3rem; margin-bottom: 10px;">🩺</div>
                        <span data-i18n="awaiting_input">Awaiting input. Your health analysis will appear here.</span>
                    </div>
                </div>
            </div>

            <!-- Right Side: Doctors & Emergency -->
            <div class="animate-fade-up" style="animation-delay: 0.2s;">

                <!-- Emergency Mini Card -->
                <div class="glass-panel" id="emergency"
                    style="margin-bottom: 30px; border-color: rgba(239, 68, 68, 0.3); background: rgba(239, 68, 68, 0.05);">
                    <div style="display: flex; align-items: flex-start; gap: 15px;">
                        <span style="font-size: 2.5rem;">🚨</span>
                        <div>
                            <h3 style="color: #fca5a5; margin-bottom: 8px;" data-i18n="emergency_title">Emergency Hotline</h3>
                            <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 15px;" data-i18n="emergency_desc">If you are
                                experiencing severe pain, bleeding, or breathing issues, immediately contact emergency
                                services.</p>
                            <a href="tel:108" class="btn-glow"
                                style="background: linear-gradient(135deg, #ef4444, #b91c1c); padding: 10px 20px; font-size: 0.95rem;" data-i18n="btn_call_ambulance">
                                Call Ambulance (108)
                            </a>
                        </div>
                    </div>
                </div>

                <div class="glass-panel">
                    <h2 class="section-header" data-i18n="specialists_title">
                        <span style="font-size: 2rem;">👨‍⚕️</span> Specialists on Call
                    </h2>

                    <div class="doctors-wrapper">
                        <!-- Dr 1 -->
                        <div class="doctor-profile">
                            <div class="doc-avatar">👨‍⚕️</div>
                            <div class="doc-info">
                                <h3>Dr. Sharma</h3>
                                <p data-i18n="doc_physician">General Physician • 15 Yrs Exp</p>
                                <div class="doc-actions">
                                    <a href="tel:9876543210" class="doc-btn btn-call">📞 <span data-i18n="btn_call">Call</span></a>
                                    <a href="https://wa.me/919876543210" class="doc-btn btn-whatsapp">💬 <span data-i18n="btn_whatsapp">WhatsApp</span></a>
                                </div>
                            </div>
                        </div>

                        <!-- Dr 2 -->
                        <div class="doctor-profile">
                            <div class="doc-avatar" style="background: linear-gradient(135deg, #f43f5e, #db2777);">👩‍⚕️
                            </div>
                            <div class="doc-info">
                                <h3>Dr. Meena</h3>
                                <p data-i18n="doc_womens">Women's Health • 12 Yrs Exp</p>
                                <div class="doc-actions">
                                    <a href="tel:9876543211" class="doc-btn btn-call">📞 <span data-i18n="btn_call">Call</span></a>
                                    <a href="https://wa.me/919876543211" class="doc-btn btn-whatsapp">💬 <span data-i18n="btn_whatsapp">WhatsApp</span></a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </main>

    <script>
        // Navbar Scrolled Effect
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if (window.scrollY > 20) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        });

        // Add Symptom to textarea
        function addSymptom(symptom) {
            const box = document.getElementById("question");
            // Highlight the pill briefly
            const btn = event.target;
            const originalBg = btn.style.background;
            btn.style.background = 'rgba(14, 165, 233, 0.4)';
            setTimeout(() => { btn.style.background = originalBg; }, 200);

            if (box.value.length > 0 && !box.value.endsWith(' ')) {
                box.value += ", ";
            }
            box.value += symptom;
            box.focus();
        }

        // Original API Call Logic matching backend expectations
        async function askAI() {
            const question = document.getElementById("question").value;
            const language = localStorage.getItem('selectedLang') || 'en';
            const fileInput = document.getElementById("imageUpload");
            const resultBox = document.getElementById("result");
            const loader = document.getElementById("loader");

            // Check if neither text nor an image is provided
            if (!question.trim() && fileInput.files.length === 0) {
                resultBox.innerHTML = `<span style="color: #fca5a5;">${getTranslation('error_no_symptoms')}</span>`;
                return;
            }

            resultBox.innerHTML = "";
            loader.style.display = "block";

            try {
                let formattedResponse = "";

                // Case 1: Image Uploaded (Hit /analyze-image directly to Python)
                if (fileInput.files.length > 0) {
                    const formData = new FormData();
                    formData.append("image", fileInput.files[0]);

                    const imageRes = await fetch("http://127.0.0.1:5000/analyze-image", {
                        method: "POST",
                        body: formData
                    });

                    if (imageRes.ok) {
                        const imgData = await imageRes.json();
                        formattedResponse += `<div style="background: rgba(139, 92, 246, 0.2); border: 1px solid rgba(139, 92, 246, 0.4); padding: 15px; border-radius: 12px; margin-bottom: 15px;">
                            <strong>🖼️ Image Scan Result:</strong><br>
                            Prediction: <span style="color: #a78bfa;">${imgData.prediction}</span><br>
                            Confidence: ${(imgData.confidence * 100).toFixed(1)}%
                        </div>`;
                    } else {
                        formattedResponse += `<div style="color: #fca5a5;">⚠️ Fail</div><br>`;
                    }
                }

                // Case 2: Text Provided (Hit /ask via Node.js Server)
                if (question.trim()) {
                    const res = await fetch("/ask", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ question, lang: language })
                    });

                    const data = await res.json();

                    let aiText = data.response
                        .replace(/\n\n/g, "<br><br>")
                        .replace(/\n/g, "<br>")
                        .replace(/•/g, "<span style='color: #0ea5e9; margin-right: 8px;'>★</span>")
                        .replace(/\*\*([^*]+)\*\*/g, "<strong style='color: #38bdf8;'>$1</strong>");

                    formattedResponse += aiText;
                }

                loader.style.display = "none";
                resultBox.innerHTML = `<div style="animation: fadeInUp 0.4s ease;">${formattedResponse}</div>`;
            } catch (err) {
                loader.style.display = "none";
                resultBox.innerHTML = `<span style="color: #fca5a5;">${getTranslation('error_api_fail')}</span>`;
                console.error(err);
            }
        }
    </script>
</body>

</html>
