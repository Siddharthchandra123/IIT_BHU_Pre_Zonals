<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pharmacy Locator | Glowing Medical Map</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/i18n.js"></script>
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    
    <style>
        #map {
            height: 70vh;
            width: 100%;
            border-radius: 24px;
            margin-top: 20px;
            z-index: 1;
            border: 1px solid var(--glass-border);
            box-shadow: var(--glass-shadow);
        }

        /* Essential Leaflet Overrides for Dark Mode */
        .leaflet-container {
            background-color: #0B1120 !important;
        }
        
        .leaflet-tile-pane {
            filter: invert(100%) hue-rotate(180deg) brightness(95%) contrast(90%);
        }

        /* Glowing Green Dot Marker */
        .glowing-marker {
            width: 12px;
            height: 12px;
            background-color: #10b981;
            border-radius: 50%;
            box-shadow: 0 0 10px #10b981;
            position: relative;
        }

        .glowing-marker::after {
            content: '';
            position: absolute;
            top: -6px;
            left: -6px;
            right: -6px;
            bottom: -6px;
            border: 2px solid #10b981;
            border-radius: 50%;
            animation: pulse-green 2s infinite;
            opacity: 0;
        }

        @keyframes pulse-green {
            0% {
                transform: scale(0.5);
                opacity: 0.8;
            }
            100% {
                transform: scale(2.5);
                opacity: 0;
            }
        }

        .map-header {
            text-align: center;
            margin-bottom: 20px;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            border-radius: 99px;
            font-size: 0.9rem;
            font-weight: 500;
            border: 1px solid rgba(16, 185, 129, 0.2);
            margin-top: 10px;
        }

        /* Tooltip Style */
        .leaflet-popup-content-wrapper {
            background: rgba(15, 23, 42, 0.95) !important;
            color: #fff !important;
            border: 1px solid rgba(14, 165, 233, 0.3) !important;
            border-radius: 12px !important;
            backdrop-filter: blur(10px);
        }
        
        .leaflet-popup-tip {
            background: rgba(15, 23, 42, 0.95) !important;
        }

        .pharmacy-label {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            color: #0ea5e9;
            margin-bottom: 4px;
        }

        .pharmacy-addr {
            font-size: 0.85rem;
            color: #94a3b8;
        }
    </style>
</head>

<body>

    <header class="navbar scrolled" id="navbar">
        <a href="/" class="brand">
            <span style="filter: drop-shadow(0 0 10px var(--primary-accent));">⚕️</span> AI Chitikshalaya
        </a>
        <nav class="nav-links">
            <a href="/" data-i18n="nav_home">Home</a>
            <a href="/home" data-i18n="nav_assistant">AI Assistant</a>
            <a href="/opd" data-i18n="nav_opd">OPD Booking</a>
            <a href="/ambulance" data-i18n="nav_ambulance">Ambulance</a>
            <a href="/hospitals" data-i18n="nav_hospitals">Find Hospitals</a>
            <a href="/pharmacies" data-i18n="nav_pharmacies">Medical Shops</a>
            <a href="/#emergency" style="color: #fca5a5; font-weight: 700;" data-i18n="nav_emergency">Emergency</a>
            
            <select class="language-selector glass-input" onchange="setLanguage(this.value)" 
                style="margin-left: 15px; padding: 5px 10px; height: auto; width: auto; font-size: 0.9rem; background: rgba(15, 23, 42, 0.8); color: white; border: 1px solid rgba(14, 165, 233, 0.3); border-radius: 8px;">
                <option value="en">🇺🇸 EN</option>
                <option value="hi">🇮🇳 HI</option>
                <option value="bn">🇮🇳 BN</option>
            </select>
        </nav>
    </header>

    <main class="main-wrapper">
        <div class="map-header animate-fade-up">
            <h1 class="hero-title animate-fade-up">
                <span class="heading-gradient" data-i18n="nav_pharmacies">Pharmacy Locator</span>
            </h1>
            <p class="hero-subtitle animate-fade-up" style="animation-delay: 0.1s;" data-i18n="feature_radar_desc">
                Find the nearest pharmacies and hospitals with our 50km Ultra-Scan ultra-wide radar.
            </p>
            <div id="status" class="status-pill" style="display: none;">
                <span class="glowing-marker" style="width: 8px; height: 8px; animation: none; box-shadow: none;"></span>
                <span id="status-text">Scanning local frequencies...</span>
            </div>
            
            <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; margin-top: 20px;">
                <button class="btn-glow" id="scanBtn" onclick="initiateScan()">
                    🛰️ Start Radar Scan
                </button>
                <button class="btn-glow" style="background: rgba(139, 92, 246, 0.2); border: 1px solid rgba(139, 92, 246, 0.4);" onclick="toggleAddForm()">
                    ➕ Add Missing Shop
                </button>
                <button class="btn-glow" style="background: rgba(30, 209, 141, 0.1); border: 1px dashed rgba(30, 209, 141, 0.4);" onclick="runSimulator()">
                    ✨ Run Simulator
                </button>
            </div>


            <!-- New Hidden Form for Adding Pharmacies -->
            <div id="addForm" style="display: none; margin-top: 30px; max-width: 500px; margin-left: auto; margin-right: auto; padding: 25px; background: rgba(15, 23, 42, 0.8); border: 1px solid var(--glass-border); border-radius: 20px;" class="animate-fade-up">
                <h3 style="margin-bottom: 15px; color: #fff;">Feed New Pharmacy Data</h3>
                <input type="text" id="newName" class="glass-input" placeholder="Pharmacy Name" style="margin-bottom: 12px; height: 45px; padding: 10px;">
                <input type="text" id="newAddr" class="glass-input" placeholder="Address" style="margin-bottom: 12px; height: 45px; padding: 10px;">
                <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 12px;">(Coordinates will be auto-set to your current location)</p>
                <button class="btn-glow" style="width: 100%; height: 45px;" onclick="addPharmacyToFeed()">Save to Local Feed</button>
            </div>
        </div>

        <div id="map" class="animate-fade-up" style="animation-delay: 0.2s;"></div>
    </main>

    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <script>
        let map;
        let markersLayer;
        let userLat, userLon;

        function initMap(lat, lon) {
            userLat = lat; userLon = lon;
            if (map) return;
            
            map = L.map('map').setView([lat, lon], 14);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);
            markersLayer = L.layerGroup().addTo(map);

            const userIcon = L.divIcon({
                className: 'user-marker',
                html: '<div style="width: 14px; height: 14px; background: #0ea5e9; border: 2px solid #fff; border-radius: 50%; box-shadow: 0 0 15px #0ea5e9;"></div>',
                iconSize: [14, 14],
                iconAnchor: [7, 7]
            });
            L.marker([lat, lon], { icon: userIcon }).addTo(map).bindPopup("<b>You are here</b>");
        }

        function toggleAddForm() {
            const form = document.getElementById('addForm');
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }

        async function addPharmacyToFeed() {
            if (!userLat) { alert("Please scan first to establish location!"); return; }
            
            const name = document.getElementById('newName').value;
            const address = document.getElementById('newAddr').value;
            
            if (!name || !address) return alert("Fill all fields!");

            const res = await fetch('/api/add-pharmacy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, address, lat: userLat, lon: userLon, source: 'local_feed' })
            });

            const data = await res.json();
            alert(data.message);
            toggleAddForm();
            initiateScan(); // Refresh
        }

        async function runSimulator() {
            if (!userLat) { 
                alert("Please click 'Start Radar Scan' first to detect your location!"); 
                return; 
            }
            
            const statusText = document.getElementById('status-text');
            const status = document.getElementById('status');
            status.style.display = 'inline-flex';
            statusText.innerText = "Simulating local Indian medical stores...";

            // Create 5 fake shops near the user
            const fakeShops = [
                { name: "Demo: Kumar Medicos", addr: "Near Main Market", offLat: 0.005, offLon: 0.005 },
                { name: "Demo: Gramin Seva Kendra", addr: "Village Entrance", offLat: -0.008, offLon: 0.003 },
                { name: "Demo: 24/7 Dawa Store", addr: "Railway Station Road", offLat: 0.002, offLon: -0.006 },
                { name: "Demo: LifeCare Pharmacy", addr: "Near Primary School", offLat: -0.004, offLon: -0.004 },
                { name: "Demo: Jan Aushadhi Store", addr: "District Hospital Gali", offLat: 0.007, offLon: -0.002 }
            ];

            fakeShops.forEach(p => {
                const glowIcon = L.divIcon({
                    className: 'custom-div-icon',
                    html: '<div class="glowing-marker" style="background-color: #facc15; box-shadow: 0 0 10px #facc15;"></div>',
                    iconSize: [12, 12],
                    iconAnchor: [6, 6]
                });

                L.marker([userLat + p.offLat, userLon + p.offLon], { icon: glowIcon })
                    .bindPopup(`<b>${p.name}</b><br>${p.addr}<br><span style="color: #facc15; font-size: 0.7rem;">SIMULATED DATA</span>`)
                    .addTo(markersLayer);
            });

            map.flyTo([userLat, userLon], 15);
            statusText.innerText = "Simulation complete. 5 stores spawned near you.";
        }

        async function initiateScan() {

            const btn = document.getElementById('scanBtn');
            const status = document.getElementById('status');
            const statusText = document.getElementById('status-text');

            btn.style.opacity = '0.5';
            status.style.display = 'inline-flex';

            if ("geolocation" in navigator) {
                navigator.geolocation.getCurrentPosition(async (position) => {
                    const { latitude, longitude } = position.coords;
                    initMap(latitude, longitude);

                    try {
                        const response = await fetch(`/api/pharmacies?lat=${latitude}&lon=${longitude}`);
                        const pharmacies = await response.json();
                        
                        if (!response.ok) {
                            statusText.innerText = pharmacies.error || "Radar connection interrupted.";
                            btn.style.opacity = '1';
                            return;
                        }

                        markersLayer.clearLayers();

                        if (pharmacies.length === 0) {
                            statusText.innerText = "No medical shops detected in range.";
                            return;
                        }

                        statusText.innerText = `${pharmacies.length} medical shops identified across hybrid sources.`;
                        
                        pharmacies.forEach(p => {
                            const isLocal = p.source === 'local_feed';
                            const glowIcon = L.divIcon({
                                className: 'custom-div-icon',
                                html: `<div class="glowing-marker" style="background-color: ${isLocal ? '#8b5cf6' : '#10b981'}; box-shadow: 0 0 10px ${isLocal ? '#8b5cf6' : '#10b981'};"></div>`,
                                iconSize: [12, 12],
                                iconAnchor: [6, 6]
                            });

                            const marker = L.marker([p.lat, p.lon], { icon: glowIcon })
                                .bindPopup(`
                                    <div class="pharmacy-label">💊 ${p.name}</div>
                                    <div class="pharmacy-addr">${p.address}</div>
                                    <div style="font-size: 0.7rem; color: #64748b; margin-top: 5px;">SOURCE: ${p.source.toUpperCase()}</div>
                                    <div style="margin-top: 8px;">
                                        <a href="https://maps.google.com/?q=${p.lat},${p.lon}" target="_blank" style="color: #10b981; text-decoration: none; font-size: 0.8rem; font-weight: 600;">Get Directions →</a>
                                    </div>
                                `);
                            markersLayer.addLayer(marker);
                        });

                    } catch (err) {
                        statusText.innerText = "Error: Link to satellite broken.";
                    }
                    btn.style.opacity = '1';
                }, () => {
                    statusText.innerText = "Error: Access to sensors denied.";
                });
            } else {
                statusText.innerText = "Error: Browser lacks geolocation protocols.";
            }
        }

        // Navbar Scroll Logic
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if (window.scrollY > 20) nav.classList.add('scrolled');
            else nav.classList.remove('scrolled');
        });
    </script>
</body>
</html>
